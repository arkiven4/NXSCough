{
  "train": { 
    "use_cuda": true,
    "log_interval": 20,
    "seed": 1234,
    "epochs": 10000,
    "learning_rate": 1e-4,
    "weight_decay": 1e-4,
    "betas": [0.8, 0.99],
    "eps": 1e-9,
    "lr_decay": 0.999875,
    "batch_size": 128,
    "loss_function": "BCELossFn",
    "use_Kfold": true,
    "n_Kfold": 10,
    "mae_training": false,
    "ssccl_training": false
  },
  "data": {
    "max_wav_value": false,
    "peak_norm": false,
    "mean_std_norm": true,
    "per_band_norm": false,
    "cmvn_norm": false,
    
    "sampling_rate": 16000,
    "filter_length": 2048,
    "hop_length": 32,
    "win_length": 1024,
    "n_mel_channels": 13,
    "mel_fmin": 120.0,
    "mel_fmax": 8000.0,

    "saming_length": false,
    "desired_length": 0.55,
    "fade_samples_ratio": 16,
    "pad_types": "zero",
    "rezize_size": [64, 256],

    "tabular_feature": true,
    "acoustic_feature": true,
    "feature_type": "logmel",
    "delta_feature": false,
    "deltadelta_feature": false,

    "multimask_augment": false,
    "multimask_prob": 0.5,
    "tau": 0.10,
    "nu": 0.10,
    "num_masks": 3,

    "augment_data": false,
    "augment_prob": 0.5,
    "augment_rawboost": false,
    "add_noise": false,

    "cough_detection": false,
    "mix_audio": false,
    "many_class": 2,

    "db_path": "",
    "metadata_csv": "metadata_coda_solicited.csv",
    "target_column": "disease_status",
    "column_order": ["path_file", "disease_status", "gender", "participant", "weight_loss", "hemoptysis", "night_sweats", "smoker"]
  }, 
  "model": {
    "pooling_model": "ResNet34ManualClassifier",
    "feature_dim": 80,
    "output_dim": 1,
    "dropout":  0.25,
    "hidden_dim_classifier": 16,
    "use_tabular": false,

    "hidden_size": 256,
    "lstmnum_layers": 4,
    "att_head": 2,
    "att_head_fusion": 1,
    "fusion_type": "gating",

    "resnet_type": "resnet18",
    "num_layers_resnet": 4,
    
    "lora_finetune": true,
    "adapter_hidden_dim": 128,
    "embedding_prompt_dim": 5,
    "lora_rank": 16,
    "lora_alpha": 32,
    "target_modules": [ "q_proj", "k_proj", "v_proj", "out_proj", "fc1", "fc2", "conv_out", "proj1", "proj2" ]
  }
}
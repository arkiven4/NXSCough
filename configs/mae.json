{
  "train": { 
    "use_cuda": true,
    "log_interval": 20,
    "seed": 1234,
    "epochs": 10000,
    "learning_rate": 1e-3,
    "betas": [0.8, 0.99],
    "eps": 1e-9,
    "lr_decay": 0.999875,
    "warmup_steps": 0,
    "scheduler": "noam",
    "batch_size": 128,
    "accumulation_steps": 1,
    "fp16_run": false,
    "loss_function": "CE"
  },
  "data": {
    "max_value_norm": false,
    "mean_std_norm": true,
    "max_wav_value": 32768.0,
    
    "sampling_rate": 16000,
    "filter_length": 1024,
    "hop_length": 256,
    "win_length": 1024,
    "n_mel_channels": 128,
    "mel_fmin": 0.0,
    "mel_fmax": 8000.0,

    "saming_length": false,
    "desired_length": 0.5,
    "fade_samples_ratio": 16,
    "pad_types": "zero",

    "mae_training": true,
    "acoustic_feature": true,
    "feature_type": "melspectogram",

    "multimask_augment": false,
    "tau": 0.20,
    "nu": 0.20,
    "num_masks": 4,
    "augment_data": true,
    "augment_rawboost": true,
    "add_noise": false,

    "mix_audio": false,
    "many_class": 3,

    "db_path": "",
    "metadata_csv": "metadata_cut_processed.csv",
    "target_column": "disease_status",
    "reorder_target": true,
    "column_order": ["path_file", "disease_status", "sex", "participant"]
  }, 
  "model": {
    "ssl_model_type": "nonssl",

    "patch_size": 16,
    "embed_dim": 768,
    "depth": 24,
    "num_heads": 24,
    "decoder_embed_dim": 512,
    "decoder_depth": 16,
    "decoder_num_heads": 16,
    "mlp_ratio": 4,
    "pooling_model": "SupervisedMaskedAutoencoderViT",
    "feature_dim": 256,
    "output_dim": 3
}
}

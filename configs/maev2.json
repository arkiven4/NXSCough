{
  "train": { 
    "use_cuda": true,
    "log_interval": 20,
    "seed": 1234,
    "epochs": 10000,
    "learning_rate": 1e-4,
    "betas": [0.8, 0.99],
    "eps": 1e-9,
    "lr_decay": 0.999875,
    "batch_size": 32,
    "loss_function": "CE",
    "use_Kfold": false
  },
  "data": {
    "mean_std_norm": true,
    
    "sampling_rate": 16000,
    "filter_length": 1024,
    "hop_length": 256,
    "win_length": 1024,
    "n_mel_channels": 128,
    "mel_fmin": 0.0,
    "mel_fmax": 8000.0,

    "saming_length": false,
    "desired_length": 0.5,
    "fade_samples_ratio": 16,
    "pad_types": "zero",

    "mae_training": true,
    "acoustic_feature": true,
    "feature_type": "melspectogram",

    "multimask_augment": true,
    "tau": 0.10,
    "nu": 0.10,
    "num_masks": 4,
    "augment_data": true,
    "augment_rawboost": true,
    "add_noise": false,

    "mix_audio": false,
    "many_class": 2,

    "db_path": "",
    "metadata_csv": "metadata_cut_processed.csv",
    "target_column": "disease_status",
    "column_order": ["path_file", "disease_status", "sex", "participant"]
  }, 
  "model": {
    "pooling_model": "SwinCoughClassifier",
    "feature_dim": 256,
    "output_dim": 2
  }
}
{
  "train": { 
    "seed": 1234,
    "use_cuda": true,
    "log_interval": 20,
    "epochs": 10000,
    "learning_rate": 3e-5,
    "betas": [0.8, 0.99],
    "eps": 1e-9,
    "lr_decay": 0.999875,
    "warmup_steps": 0,
    "scheduler": "noam",
    "batch_size": 32,
    "accumulation_steps": 1,
    "fp16_run": false,
    "loss_function": "CE"
  },
  "data": {
    "max_value_norm": false,
    "mean_std_norm": true,
    "max_wav_value": 32768.0,

    "sampling_rate": 16000,
    "filter_length": 1024,
    "hop_length": 256,
    "win_length": 1024,
    "n_mel_channels": 128,
    "mel_fmin": 0.0,
    "mel_fmax": 8000.0,

    "saming_length": false,
    "desired_length": 3.0,
    "fade_samples_ratio": 16,
    "pad_types": "synthesis",

    "acoustic_feature": true,
    "feature_type": "melspectogram",

    "multimask_augment": true,
    "tau": 0.10,
    "nu": 0.10,
    "num_masks": 4,
    "augment_data": true,
    "augment_rawboost": true,
    "add_noise": false,

    "mix_audio": false,
    "many_class": 2,

    "db_path": "",
    "metadata_csv": "metadata_cut_processed.csv",
    "target_column": "disease_status",
    "reorder_target": true,
    "column_order": ["path_file", "disease_status", "sex", "participant"]
  }, 
  "model": {
    "ssl_model_type": "nonssl",

    "finetune_method": "lora",
    "adapter_hidden_dim": 128,
    "embedding_prompt_dim": 5,
    "lora_rank": 32,
    "lora_alpha": 64,
    "target_modules" : ["q_proj", "k_proj", "v_proj", "out_proj", "intermediate_dense", "output_dense"],
    "use_conv_output": true,

    "grl_lambda": 5.0,
    "pooling_model": "ViTMel",
    "feature_dim": 128,
    "p_dropout": 0.1,
    "num_transformer_layers": 12,
    "regress_hidden_dim": 1024,
    "regress_dropout": 0.1,
    "regress_layers": 1,
    "output_dim": 2
  }
}

{
  "train": { 
    "use_cuda": true,
    "log_interval": 20,
    "seed": 1234,
    "epochs": 10000,
    "learning_rate": 5e-5,
    "betas": [0.8, 0.99],
    "eps": 1e-9,
    "lr_decay": 0.999875,
    "batch_size": 16,
    "loss_function": "CE",
    "use_Kfold": true,
    "mae_training": false,
    "ssccl_training": false
  },
  "data": {
    "max_wav_value": false,
    "mean_std_norm": true,
    
    "sampling_rate": 16000,
    "filter_length": 1024,
    "hop_length": 256,
    "win_length": 1024,
    "n_mel_channels": 64,
    "mel_fmin": 0.0,
    "mel_fmax": 8000.0,

    "saming_length": true,
    "desired_length": 0.55,
    "fade_samples_ratio": 16,
    "pad_types": "zero",
    "rezize_size": [64, 256],

    "acoustic_feature": true,
    "feature_type": "melspectogram",
    "delta_feature": false,

    "multimask_augment": false,
    "tau": 0.10,
    "nu": 0.10,
    "num_masks": 2,

    "augment_data": true,
    "augment_prob": 0.4,
    "augment_rawboost": false,
    "add_noise": false,

    "mix_audio": false,
    "many_class": 2,

    "db_path": "",
    "metadata_csv": "metadata.csv",
    "target_column": "disease_status",
    "column_order": ["path_file", "disease_status", "sex", "participant"]
  }, 
  "model": {
    "pooling_model": "BiLSTMSelfAttClassifier",
    "feature_dim": 64,
    "output_dim": 2
  }
}